.DS_Store

# Transfer artifact (contains plaintext source)
files.zip

# Private gate sources — keep local, never publish (build.js holds the password)
liam/index.source.html
liam/build.js
*.source.html

# Norvège 2026 — receipts are embedded (encrypted) inside index.html behind the
