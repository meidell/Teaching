# Copy to .env for local dev. NEVER commit .env (it's git-ignored).

# Postgres connection string (the shared Render "teaching_db").
DATABASE_URL=

# Anthropic API key — server-side ONLY, never shipped to the browser.
ANTHROPIC_API_KEY=

# Coaching model. Opus 4.8 is the default; claude-haiku-4-5 or
# claude-sonnet-4-6 are cheaper if you want to cut cost.
COACH_MODEL=claude-opus-4-8

# Comma-separated front-end origins allowed to call /api/*
# e.g. https://thesis-web.onrender.com,https://www.hesge.ch
ALLOWED_ORIGINS=

# Local dev port (Render sets PORT automatically in production).
PORT=10000
